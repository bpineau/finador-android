<?xml version="1.0" encoding="utf-8"?>
<!-- Pre-Android-12 counterpart of data_extraction_rules.xml: exclude everything from auto backup.
     allowBackup="false" already disables backups outright; these rules make the exclusion explicit
     should that flag ever be flipped. -->
<full-backup-content>
    <exclude domain="root" path="." />
    <exclude domain="file" path="." />
    <exclude domain="sharedpref" path="." />
    <exclude domain="database" path="." />
    <exclude domain="external" path="." />
</full-backup-content>
