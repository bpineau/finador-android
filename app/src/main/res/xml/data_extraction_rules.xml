<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ reads these rules instead of allowBackup for cloud backup and device-to-device
     transfer. Exclude everything explicitly: the app holds Keystore-encrypted secrets and a
     working copy of the ledger, and a restore onto another device could not decrypt them anyway
     (the Keystore key never leaves the original hardware). allowBackup="false" stays in the
     manifest for pre-12 devices. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="." />
        <exclude domain="file" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="database" path="." />
        <exclude domain="external" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="." />
        <exclude domain="file" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="database" path="." />
        <exclude domain="external" path="." />
    </device-transfer>
</data-extraction-rules>
